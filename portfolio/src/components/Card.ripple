export component Card(props: { id?: string, children: any }){
    <div class="card" id={props.id}>
        <props.children />
    </div>
    <style>
        .card {
            border: 1px solid var(--border);
            background: var(--panel);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            padding: 1.5rem;
            gap: 1rem;
            width: 100%;
        }
    </style>
}